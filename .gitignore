# --- Secrets & environment ---
.env
.env.*
*.pem
*.key
*.p12
*.pfx
id_rsa*
# (note: topics/*/levels/*/starter/secrets/ and topics/*/levels/*/workspace/secrets/
#  are intentional exercise content and committed. This rule only catches real .env files.)

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.python-version
.pytest_cache/
.tox/
.coverage
htmlcov/

# --- Node.js / frontend ---
node_modules/
dist/
build/
.next/
.nuxt/
.parcel-cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Databases (interns generate these during assignments) ---
*.db
*.sqlite
*.sqlite3
# But keep any intentionally-committed seed/schema SQL
!*.sql

# --- Generated project artifacts (interns create these during assignments) ---
topics/*/levels/*/workspace/
tasks.db
output.html
*.log

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- OS ---
.DS_Store
desktop.ini

# --- Personal progress (interns copy templates to these — they're personal, not for the repo) ===
MY_PROGRESS.md
MY_CHECKLIST.md
MY_DESIGN.md
